<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Camera preview takes top 45% of screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/ocr_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="45"
        app:implementationMode="compatible"/>

    <!-- Read button always visible below preview -->
    <Button
        android:id="@+id/btn_read"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:text="Read Text Aloud"
        android:textSize="16sp"/>

    <!-- Result text takes remaining space -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="55"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_ocr_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Point camera at any text then tap Read."
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.6"/>

    </ScrollView>

</LinearLayout>